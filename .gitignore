# ============================================================
# ESP-IDF build artefacts
# ============================================================

# Build directory produced by idf.py build
build/
build_*/
out/

# Managed component dependencies (idf.py build fetches them)
managed_components/
dependencies.lock

# ESP-IDF SDK configuration (generated by idf.py)
sdkconfig
sdkconfig.old
sdkconfig.*
!sdkconfig.defaults

# Python / virtualenv
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Editor / OS junk
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Toolchain / IDF install
.toolchain_version
.espressif/

# Log files
*.log

# Build helper scratch
.cache/
.eslintcache
